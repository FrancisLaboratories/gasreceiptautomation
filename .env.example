# ============================================================
# Gas Receipt Automation — Environment Variables
# ============================================================
# Copy to .env and fill in values.

# --- Server ---
PORT=8003
LUBELOGGER_URL=http://lubelogger:8080
LLM_API_KEY=
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
LLM_MODEL=gemini-2.5-flash-lite

# --- Auth0 (server-side JWT verification) ---
AUTH0_DOMAIN=
AUTH0_API_AUDIENCE=
AUTH0_ISSUER=
AUTH0_ALGORITHMS=RS256

# --- Client (served to browser via /config.js) ---
PUBLIC_AUTH0_DOMAIN=
PUBLIC_AUTH0_CLIENT_ID=
PUBLIC_AUTH0_AUDIENCE=
PUBLIC_AUTH0_REDIRECT_URI=
